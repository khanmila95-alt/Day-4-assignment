class Animal {
    void eat() {
        System.out.println("This animal eats food");
    }
}


class Dog extends Animal {
    void bark() {
        System.out.println("Dog barks");
    }
}

public class Main {
    public static void main(String[] args) {
        Dog d1 = new Dog();

        d1.eat();   
        d1.bark(); 
    }
}
